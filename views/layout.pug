<!DOCTYPE html>
html(class="no-js" lang="en" dir="ltr")
  head
    meta(charset='utf-8')
    meta(http-equiv='x-ua-compatible', content='ie=edge')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title Portfolio Site
    link(href='https://fonts.googleapis.com/css?family=Merriweather:300,400,400i,700,800', rel='stylesheet')
    link(rel='stylesheet', href='/static/css/foundation.css')
    link(rel='stylesheet', href='/static/css/all.min.css')
    link(rel='stylesheet', href='/static/css/style.css')
  body
    #my-info.off-canvas.position-left.reveal-for-large.portfolio-me(data-off-canvas='')
      .grid-y.grid-padding-x(style='height: 100%;')
        block sidebar
          br
          .cell.shrink
            img.thumbnail(src='/static/images/portrait-500x500.jpg')
          .cell.auto

            //- Add your name here.
            h5 John Nguyen

            //- Add text here to describe who you are, what you do, and why you are so awesome.
            p.text-light
              | Full Stack JavaScript Developer

            //- Add about page route to the href below.
            ul#sidebar-nav.vertical.menu.align-center
              li
                  a(href='/') Home
              li
                a(href='/about') About

            ul.social-list.menu.align-center
              li
                a(href='mailto:nguyen.johnsan@gmail.com' target='_blank')
                  i.fas.fa-envelope-square.fa-2x
              li
                a(href='https://github.com/john-san' target='_blank')
                  i.fab.fa-github-square.fa-2x
              li
                a(href='https://www.linkedin.com/in/john-san/' target='_blank')
                  i.fab.fa-linkedin.fa-2x
              
              

    .off-canvas-content(data-off-canvas-content='')
      .title-bar.hide-for-large
        .title-bar-left
          button.menu-icon(type='button', data-toggle='my-info')

          //- Add your name here.  This is for the mobile screen sized version.
          span.title-bar-title John Nguyen
      block content
        

      
  script(src='/static/js/vendor/jquery.js')
  script(src='/static/js/vendor/what-input.js')
  script(src='/static/js/vendor/foundation.js')
  script(src='/static/js/scripts.js')
